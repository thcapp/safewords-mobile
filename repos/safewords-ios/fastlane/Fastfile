require "fileutils"
require "json"
require "shellwords"
require "spaceship"

default_platform(:ios)

APP_IDENTIFIER = "app.thc.safewords"
WIDGET_IDENTIFIER = "app.thc.safewords.widget"
APP_IDENTIFIERS = [APP_IDENTIFIER, WIDGET_IDENTIFIER].freeze
APP_STORE_NAME = "Safewords - Verify Identity"
APP_VERSION = "1.3.1"
SCHEME = "Safewords"

IOS_ROOT = File.expand_path("..", __dir__)
REPO_ROOT = File.expand_path("../..", IOS_ROOT)
PROJECT_PATH = File.join(IOS_ROOT, "Safewords.xcodeproj")
OUTPUT_DIR = File.join(REPO_ROOT, "output/app-store/ios")
IPA_PATH = File.join(OUTPUT_DIR, "Safewords.ipa")
LOCAL_CREDENTIALS_PATH = File.join(REPO_ROOT, "output/app-store/credentials.json")
LOCAL_KEY_PATH = File.join(REPO_ROOT, "output/app-store/AuthKey_355BYQMBRM.p8")
METADATA_PATH = File.join(__dir__, "metadata")
SCREENSHOTS_PATH = File.join(__dir__, "screenshots")
APP_RATING_CONFIG_PATH = File.join(__dir__, "app_rating_config.json")
APP_PRIVACY_DETAILS_PATH = File.join(__dir__, "app_privacy_details.json")

# Maestro flows live at the repo root, shared between iOS + Android runs.
MAESTRO_FLOWS_DIR = File.join(REPO_ROOT, "maestro/flows")
MAESTRO_SCREENSHOTS_DIR = File.join(REPO_ROOT, "maestro/screenshots")
# iOS Maestro target — set when boot succeeds.
MAESTRO_IOS_DEVICE = "iPhone 15"

def _maestro_path_prefix
  # The macos-latest runner has Xcode + simctl on the default PATH but Maestro
  # may not be installed yet (CI installs it via brew before the lane runs);
  # local Mac users typically install via the curl|bash script that drops
  # ~/.maestro/bin. Cover both. MAESTRO_CLI_* envs suppress the analytics
  # banners that pollute CI logs.
  %(export PATH="$HOME/.maestro/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"; ) +
    %(export MAESTRO_CLI_NO_ANALYTICS=1; ) +
    %(export MAESTRO_CLI_ANALYSIS_NOTIFICATION_DISABLED=true; )
end

def _maestro_run_flow(flow_path)
  full = File.join(MAESTRO_FLOWS_DIR, flow_path)
  UI.user_error!("Maestro flow not found: #{full}") unless File.exist?(full)
  sh("bash -c '#{_maestro_path_prefix} cd #{Shellwords.escape(MAESTRO_FLOWS_DIR)} && maestro test #{Shellwords.escape(flow_path)}'")
end

# Boot the iPhone simulator if it isn't already, install the latest debug
# build, return the booted UDID. The macos-latest runner ships every recent
# iOS Simulator runtime; we let `xcrun simctl` pick the first matching device
# by name from `simctl list devices available`.
def _maestro_boot_ios_simulator!
  device = MAESTRO_IOS_DEVICE
  list_json = `xcrun simctl list devices available --json 2>/dev/null`
  parsed = JSON.parse(list_json) rescue { "devices" => {} }
  match = nil
  (parsed["devices"] || {}).each do |_runtime, devs|
    devs.each do |d|
      if d["name"] == device
        match = d
        break
      end
    end
    break if match
  end
  UI.user_error!("No '#{device}' simulator available on this runner") unless match

  if match["state"] != "Booted"
    sh("xcrun simctl boot '#{match["udid"]}'")
    # simctl returns immediately after issuing the boot; SpringBoard isn't
    # ready for a few seconds. bootstatus blocks until the device is usable.
    sh("xcrun simctl bootstatus '#{match["udid"]}' -b")
  end
  match["udid"]
end

def local_credentials
  @local_credentials ||= begin
    File.exist?(LOCAL_CREDENTIALS_PATH) ? JSON.parse(File.read(LOCAL_CREDENTIALS_PATH)) : {}
  end
end

def credential_value(*keys)
  keys.each do |key|
    value = local_credentials[key]
    return value.to_s.strip if value.to_s.strip.length.positive?
  end
  nil
end

def absolute_path(path)
  return nil if path.to_s.strip.empty?
  return path if File.absolute_path(path) == path

  File.expand_path(path, REPO_ROOT)
end

def apple_team_id
  team_id = ENV["APPLE_TEAM_ID"] || ENV["FASTLANE_TEAM_ID"] || credential_value("team_id")
  UI.user_error!("APPLE_TEAM_ID is required for signing and match") if team_id.to_s.strip.empty?
  team_id
end

def asc_api_key
  @asc_api_key ||= begin
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"] || credential_value("key_id")
    issuer_id = ENV["APP_STORE_CONNECT_API_ISSUER_ID"] || credential_value("issuer_id")
    key_base64 = ENV["APP_STORE_CONNECT_API_KEY_BASE64"]
    key_path = absolute_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"] || credential_value("key_filepath") || LOCAL_KEY_PATH)

    UI.user_error!("APP_STORE_CONNECT_API_KEY_ID is required") if key_id.to_s.strip.empty?
    UI.user_error!("APP_STORE_CONNECT_API_ISSUER_ID is required") if issuer_id.to_s.strip.empty?

    if key_base64.to_s.strip.length.positive?
      app_store_connect_api_key(
        key_id: key_id,
        issuer_id: issuer_id,
        key_content: key_base64,
        is_key_content_base64: true,
        duration: 1200,
        in_house: false
      )
    else
      UI.user_error!("App Store Connect API key file not found at #{key_path}") unless File.exist?(key_path)
      app_store_connect_api_key(
        key_id: key_id,
        issuer_id: issuer_id,
        key_filepath: key_path,
        duration: 1200,
        in_house: false
      )
    end
  end
end

def ensure_xcodegen_project!
  UI.user_error!("xcodegen is required; install with `brew install xcodegen`") unless system("command -v xcodegen >/dev/null 2>&1")

  Dir.chdir(IOS_ROOT) do
    sh("xcodegen generate")
  end
end

def ensure_match_env!
  %w[MATCH_GIT_URL MATCH_PASSWORD].each do |name|
    UI.user_error!("#{name} is required for match") if ENV[name].to_s.strip.empty?
  end
end

def appstore_profile_names
  {
    APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}",
    WIDGET_IDENTIFIER => "match AppStore #{WIDGET_IDENTIFIER}"
  }
end

def sync_appstore_profiles(readonly:)
  ensure_match_env!
  setup_ci if ENV["CI"] == "true"

  # GitHub Actions' actions/checkout@v4 sets a global http.extraheader with
  # GITHUB_TOKEN scoped to the current repo only. Combining that with
  # MATCH_GIT_BASIC_AUTHORIZATION causes git's credential resolution to fall
  # back to the username prompt and fail. Embed credentials in the URL
  # directly, and clear all conflicting auth state.
  url = ENV["MATCH_GIT_URL"].to_s
  if ENV["CI"] == "true"
    # MATCH_GIT_BASIC_AUTHORIZATION is base64("thcllc:TOKEN"). Decode and
    # extract the TOKEN to embed in the URL as x-access-token credentials.
    require "base64"
    basic = ENV["MATCH_GIT_BASIC_AUTHORIZATION"].to_s
    token = ""
    if !basic.empty?
      decoded = Base64.decode64(basic)
      token = decoded.split(":", 2).last.to_s.strip
    end

    if !token.empty? && url.start_with?("https://github.com/")
      url = url.sub("https://github.com/", "https://x-access-token:#{token}@github.com/")
    end

    sh("git config --global --unset-all http.https://github.com/.extraheader || true")
    sh("git config --global --remove-section http.https://github.com/ 2>/dev/null || true")
    sh("git config --global --unset-all credential.helper || true")
    ENV["MATCH_GIT_BASIC_AUTHORIZATION"] = nil
    ENV["GIT_CONFIG_PARAMETERS"] = "'credential.helper='"
    ENV["GIT_TERMINAL_PROMPT"] = "0"

    # The workflow's Materialize step writes the raw .p8 to
    # APP_STORE_CONNECT_API_KEY_PATH. Modern fastlane expects that env var to
    # point to a JSON wrapper file, NOT a raw PEM. Convert it: read the .p8,
    # write a JSON wrapper next to it, repoint the env var.
    raw_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"].to_s
    if !raw_path.empty? && File.exist?(raw_path)
      require "json"
      pem = File.read(raw_path)
      json_path = raw_path.sub(/\.p8\z/, "") + ".json"
      File.write(json_path, JSON.generate({
        "key_id" => ENV["APP_STORE_CONNECT_API_KEY_ID"],
        "issuer_id" => ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        "key" => pem,
        "in_house" => false
      }))
      File.chmod(0600, json_path)
      ENV["APP_STORE_CONNECT_API_KEY_PATH"] = json_path
    end
  end

  match(
    type: "appstore",
    app_identifier: APP_IDENTIFIERS,
    team_id: apple_team_id,
    git_url: url,
    readonly: readonly,
    storage_mode: "git",
    force: !readonly,
    force_for_new_devices: !readonly,
    include_all_certificates: !readonly
  )
end

def configure_code_signing!
  update_code_signing_settings(
    use_automatic_signing: false,
    path: PROJECT_PATH,
    team_id: apple_team_id,
    targets: ["Safewords"],
    code_sign_identity: "Apple Distribution",
    profile_name: "match AppStore #{APP_IDENTIFIER}"
  )
  update_code_signing_settings(
    use_automatic_signing: false,
    path: PROJECT_PATH,
    team_id: apple_team_id,
    targets: ["SafewordsWidget"],
    code_sign_identity: "Apple Distribution",
    profile_name: "match AppStore #{WIDGET_IDENTIFIER}"
  )
end

def screenshot_files?
  Dir.glob(File.join(SCREENSHOTS_PATH, "**", "*.{png,jpg,jpeg}")).any?
end

def submission_information
  {
    export_compliance_uses_encryption: false,
    add_id_info_uses_idfa: false
  }
end

platform :ios do
  desc "Create or refresh App Store signing assets in the configured match repo"
  lane :match_setup do
    ensure_xcodegen_project!
    sync_appstore_profiles(readonly: false)
    UI.success("match app-store profiles are ready for #{APP_IDENTIFIERS.join(', ')}")
  end

  desc "Build a signed App Store IPA"
  lane :build do
    ensure_xcodegen_project!
    sync_appstore_profiles(readonly: true)
    configure_code_signing!

    # Select the highest-version Xcode installed on the runner. Apple now
    # requires apps built with the iOS 26 SDK or later (Xcode 26+) for App
    # Store submission. The workflow's default `xcode-select -s Xcode.app`
    # may resolve to an older version (Xcode 16.4 ships iOS 18.5 SDK).
    if ENV["CI"] == "true"
      xcode_apps = Dir.glob("/Applications/Xcode_*.app").sort_by do |path|
        # Sort by parsed version to pick the newest (e.g. Xcode_26.0.app > Xcode_16.4.app)
        File.basename(path).gsub("Xcode_", "").gsub(".app", "").split(".").map { |n| n.to_i }
      end
      latest_xcode = xcode_apps.last
      if latest_xcode
        UI.message("Selecting #{latest_xcode}")
        sh("sudo xcode-select -s '#{latest_xcode}/Contents/Developer'")
        sh("xcodebuild -version")
        sh("xcrun --show-sdk-version --sdk iphoneos")
      else
        UI.important("No Xcode_*.app found in /Applications; using default selection")
      end
    end

    # Diagnostic: dump entitlements of every installed provisioning profile so
    # we can confirm App Groups (and others) actually made it onto disk.
    if ENV["CI"] == "true"
      profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
      UI.message("=" * 70)
      UI.message("Installed provisioning profiles + entitlements:")
      UI.message("=" * 70)
      Dir.glob(File.join(profiles_dir, "*.mobileprovision")).each do |path|
        UI.message("--- #{File.basename(path)} ---")
        begin
          plist = `security cms -D -i "#{path}" 2>/dev/null`
          name_match = plist.match(/<key>Name<\/key>\s*<string>([^<]+)<\/string>/)
          UI.message("  Name: #{name_match[1]}") if name_match
          uuid_match = plist.match(/<key>UUID<\/key>\s*<string>([^<]+)<\/string>/)
          UI.message("  UUID: #{uuid_match[1]}") if uuid_match
          ent_match = plist.match(/<key>Entitlements<\/key>\s*<dict>(.*?)<\/dict>/m)
          if ent_match
            UI.message("  Entitlements:")
            ent_match[1].scan(/<key>([^<]+)<\/key>\s*(?:<string>([^<]*)<\/string>|<array>(.*?)<\/array>|<true\/>|<false\/>)/m).each do |k, str, arr|
              if arr
                arr.scan(/<string>([^<]+)<\/string>/).each { |s| UI.message("    #{k}: #{s[0]}") }
              else
                UI.message("    #{k}: #{str || '(bool)'}")
              end
            end
          end
        rescue => e
          UI.error("  could not parse: #{e.message}")
        end
      end
      UI.message("=" * 70)
    end

    sh("mkdir -p #{OUTPUT_DIR}")
    build_app(
      project: PROJECT_PATH,
      scheme: SCHEME,
      clean: true,
      export_method: "app-store",
      output_directory: OUTPUT_DIR,
      output_name: "Safewords.ipa",
      xcargs: "DEVELOPMENT_TEAM=#{apple_team_id}",
      export_options: {
        signingStyle: "manual",
        teamID: apple_team_id,
        provisioningProfiles: appstore_profile_names
      }
    )
    [
      "Payload/Safewords.app/bip39-english.txt",
      "Payload/Safewords.app/safety-card-copy.json",
      "Payload/Safewords.app/PlugIns/SafewordsWidget.appex/adjectives.json",
      "Payload/Safewords.app/PlugIns/SafewordsWidget.appex/nouns.json",
      "Payload/Safewords.app/PlugIns/SafewordsWidget.appex/safety-card-copy.json"
    ].each do |resource|
      sh("unzip -l #{Shellwords.escape(IPA_PATH)} | grep -q #{Shellwords.escape(resource)}")
    end
    UI.success("Built IPA at #{IPA_PATH}")
  end

  desc "Build + upload to TestFlight"
  lane :beta do
    # Smoke gate. Fails closed before any IPA upload — if the phase-1 Maestro
    # flows don't all pass against a fresh debug build on the simulator, we
    # never push to TestFlight. See docs/maestro-plan.md.
    maestro_test
    build
    # Bypass app_store_connect_api_key action — its Spaceship token init
    # hits OpenSSL::PKey::ECError "invalid curve name" on macos-arm64 runners
    # (fastlane issue #20593). Pass api_key_path directly; upload_to_testflight
    # parses the JSON wrapper itself with a different code path that works.
    api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    if ENV["CI"] == "true" && api_key_path && File.exist?(api_key_path)
      upload_to_testflight(
        api_key_path: api_key_path,
        app_identifier: APP_IDENTIFIER,
        ipa: IPA_PATH,
        skip_waiting_for_build_processing: true,
        distribute_external: false
      )
    else
      upload_to_testflight(
        api_key: asc_api_key,
        app_identifier: APP_IDENTIFIER,
        ipa: IPA_PATH,
        skip_waiting_for_build_processing: true,
        distribute_external: false
      )
    end
    UI.success("#{APP_STORE_NAME} uploaded to TestFlight")
  end

  desc "Build + upload metadata/binary and submit to App Store Review"
  lane :release do
    build
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: APP_VERSION,
      ipa: IPA_PATH,
      metadata_path: METADATA_PATH,
      screenshots_path: SCREENSHOTS_PATH,
      skip_screenshots: !screenshot_files?,
      app_rating_config_path: APP_RATING_CONFIG_PATH,
      submission_information: submission_information,
      submit_for_review: true,
      automatic_release: false,
      run_precheck_before_submit: true,
      force: true
    )
    UI.success("#{APP_STORE_NAME} submitted for App Store Review")
  end

  desc "Confirm snapshot scaffolding is present"
  lane :snapshot_setup do
    ensure_xcodegen_project!
    UI.message("Snapshot UI test scaffold: #{File.join(IOS_ROOT, 'SafewordsUITests')}")
    UI.message("Run `bundle exec fastlane ios screenshots` on a macOS runner after the first signed build is healthy.")
  end

  desc "Capture App Store screenshots with fastlane snapshot"
  lane :screenshots do
    ensure_xcodegen_project!
    capture_ios_screenshots(
      scheme: SCHEME,
      output_directory: SCREENSHOTS_PATH,
      devices: ["iPhone 16 Pro Max"],
      languages: ["en-US"],
      clear_previous_screenshots: true,
      reinstall_app: true,
      override_status_bar: true
    )
    UI.success("Screenshots captured under #{SCREENSHOTS_PATH}")
  end

  desc "Push listing metadata, age rating, and screenshots without uploading an IPA"
  lane :metadata do
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: APP_VERSION,
      metadata_path: METADATA_PATH,
      screenshots_path: SCREENSHOTS_PATH,
      skip_binary_upload: true,
      skip_screenshots: !screenshot_files?,
      app_rating_config_path: APP_RATING_CONFIG_PATH,
      submission_information: submission_information,
      submit_for_review: false,
      run_precheck_before_submit: true,
      force: true
    )

    UI.important("App Privacy nutrition is staged at #{APP_PRIVACY_DETAILS_PATH}, but fastlane cannot upload it with an App Store Connect API key only.")
    UI.important("If Apple requires a privacy refresh, use an owner/admin Apple ID with `upload_app_privacy_details_to_app_store`, or fill the no-data form in App Store Connect.")
  end

  desc "Upload App Privacy nutrition; requires Apple ID owner/admin auth, not ASC API key"
  lane :privacy do
    UI.user_error!("FASTLANE_USER is required because Apple does not expose App Privacy upload through the App Store Connect API key flow") if ENV["FASTLANE_USER"].to_s.strip.empty?

    upload_app_privacy_details_to_app_store(
      username: ENV["FASTLANE_USER"],
      app_identifier: APP_IDENTIFIER,
      team_id: apple_team_id,
      json_path: APP_PRIVACY_DETAILS_PATH
    )
    UI.success("Uploaded no-data App Privacy nutrition from #{APP_PRIVACY_DETAILS_PATH}")
  end

  desc "Dry-run App Store Connect credentials and app lookup"
  lane :validate do
    require "spaceship"
    require "base64"

    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"] || credential_value("key_id")
    issuer_id = ENV["APP_STORE_CONNECT_API_ISSUER_ID"] || credential_value("issuer_id")
    key_base64 = ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s
    raw_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"].to_s
    key_path = absolute_path(raw_path.empty? ? (credential_value("key_filepath") || LOCAL_KEY_PATH) : raw_path)

    pem_text =
      if key_base64.length.positive?
        Base64.decode64(key_base64)
      elsif !key_path.to_s.empty? && File.exist?(key_path)
        contents = File.read(key_path)
        # Path may already be a JSON wrapper (workflow Materialize step)
        contents.start_with?("{") ? JSON.parse(contents)["key"] : contents
      else
        UI.user_error!("No App Store Connect API key available")
      end

    token = Spaceship::ConnectAPI::Token.create(
      key_id: key_id,
      issuer_id: issuer_id,
      key: pem_text,
      duration: 1200,
      in_house: false
    )
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.user_error!("App Store Connect app not found for #{APP_IDENTIFIER}") if app.nil?

    UI.success("App Store Connect API key can access #{app.name} (#{APP_IDENTIFIER})")
    UI.message("Home screen display name remains Safewords; App Store listing name is #{APP_STORE_NAME}.")

    # Bundle ID capability dump — diagnose App Groups assignment
    UI.message("=" * 70)
    UI.message("DIAGNOSTIC: Bundle ID capabilities + linked App Groups")
    UI.message("=" * 70)
    APP_IDENTIFIERS.each do |bundle|
      UI.message("--- #{bundle} ---")
      bid = Spaceship::ConnectAPI::BundleId.find(bundle)
      if bid.nil?
        UI.error("  NOT FOUND on Apple's portal")
        next
      end
      UI.message("  bundle_id record_id: #{bid.id}")

      # Capabilities
      caps = bid.get_capabilities
      if caps.empty?
        UI.error("  NO CAPABILITIES enabled")
      else
        caps.each do |c|
          UI.message("  capability: #{c.capability_type}")
        end
      end

      # Linked App Groups — via the relationship endpoint, NOT via capabilities
      begin
        client = Spaceship::ConnectAPI.client
        resp = client.get("bundleIds/#{bid.id}/appGroups")
        groups = resp.body["data"] || []
        if groups.empty?
          UI.error("  ⚠️  NO APP GROUPS LINKED to this Bundle ID")
        else
          groups.each do |g|
            attrs = g["attributes"] || {}
            UI.message("  ✓  linked group: identifier=#{attrs["identifier"]} name=#{attrs["name"]}")
          end
        end
      rescue => e
        UI.error("  Could not query linked groups: #{e.class}: #{e.message}")
      end
    end

    UI.message("--- All App Groups in account ---")
    begin
      client = Spaceship::ConnectAPI.client
      resp = client.get("appGroups")
      groups = resp.body["data"] || []
      if groups.empty?
        UI.error("  ⚠️  NO APP GROUPS exist in the account at all")
      else
        groups.each do |g|
          attrs = g["attributes"] || {}
          UI.message("  group_record id=#{g["id"]}: identifier=#{attrs["identifier"]} name=#{attrs["name"]}")
        end
      end
    rescue => e
      UI.error("  Could not list account App Groups: #{e.class}: #{e.message}")
    end
    UI.message("=" * 70)
  end
  desc "Diagnose bundle ID capabilities at Apple Developer Portal"
  lane :diag_caps do
    require "spaceship"
    require "base64"
    require "json"

    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_API_ISSUER_ID"]
    raw_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"].to_s

    pem =
      if !raw_path.empty? && File.exist?(raw_path)
        contents = File.read(raw_path)
        contents.start_with?("{") ? JSON.parse(contents)["key"] : contents
      else
        Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s)
      end

    token = Spaceship::ConnectAPI::Token.create(
      key_id: key_id, issuer_id: issuer_id, key: pem,
      duration: 1200, in_house: false
    )
    Spaceship::ConnectAPI.token = token

    APP_IDENTIFIERS.each do |bundle|
      puts "==="
      puts "BundleID: #{bundle}"
      bid = Spaceship::ConnectAPI::BundleId.find(bundle)
      if bid.nil?
        puts "  NOT FOUND"
        next
      end
      caps = bid.get_capabilities
      caps.each do |cap|
        puts "  capability: #{cap.capability_type} settings=#{cap.settings.inspect}"
      end
    end
  end

  desc "Run Maestro phase-1 smoke flows against a freshly-booted iOS simulator. Fails closed."
  lane :maestro_test do
    ensure_xcodegen_project!
    udid = _maestro_boot_ios_simulator!
    UI.message("Maestro target simulator: #{MAESTRO_IOS_DEVICE} (#{udid})")

    # Build a debug .app for the simulator and install it onto the booted
    # device. We use xcodebuild directly rather than gym/build_app — gym
    # produces an .ipa for device, not a .app for the simulator. The
    # ${DERIVED_DATA}/Build/Products/Debug-iphonesimulator/Safewords.app
    # path is the canonical location.
    derived = File.join(IOS_ROOT, "build/maestro-derived")
    sh("rm -rf #{Shellwords.escape(derived)}")
    sh(
      "xcodebuild -project #{Shellwords.escape(PROJECT_PATH)} " \
      "-scheme #{Shellwords.escape(SCHEME)} " \
      "-configuration Debug " \
      "-destination 'platform=iOS Simulator,id=#{udid}' " \
      "-derivedDataPath #{Shellwords.escape(derived)} " \
      "CODE_SIGNING_ALLOWED=NO " \
      "build"
    )
    app_path = File.join(derived, "Build/Products/Debug-iphonesimulator/Safewords.app")
    UI.user_error!("Sim build did not produce #{app_path}") unless File.directory?(app_path)
    sh("xcrun simctl install #{udid} #{Shellwords.escape(app_path)}")

    %w[
      onboarding-create.yaml
      onboarding-restore.yaml
      onboarding-demo.yaml
      parity-check.yaml
    ].each do |flow|
      UI.message("Maestro flow: #{flow}")
      _maestro_run_flow(flow)
    end

    UI.success("All 4 phase-1 Maestro flows passed on iOS simulator")
  end

  # Device matrix for the App Store screenshot mandate. Each tuple is:
  # [simulator_device_name, output_subdir_under_screenshots/en-US, label].
  #
  # All four sim device types ship by default with the macos-latest runner's
  # bundled iOS 18+ runtimes. iPhone SE 3rd gen covers Apple's legacy 5.5"
  # slot (still required for new submissions). iPad Pro 12.9" is included
  # by default; the project ships a Universal target so iPad is in scope.
  SCREENSHOT_MATRIX = [
    ["iPhone 15 Pro Max",                   "iPhone67",   "6.7\" (iPhone 15 Pro Max)"],
    ["iPhone 15 Plus",                      "iPhone65",   "6.5\" (iPhone 15 Plus)"],
    ["iPhone SE (3rd generation)",          "iPhone55",   "5.5\" (iPhone SE 3rd gen)"],
    ["iPad Pro (12.9-inch) (6th generation)", "iPadPro129", "12.9\" (iPad Pro)"]
  ].freeze

  # Boot a named simulator and return its UDID. Reuses the booted device if
  # one is already up, falls back to creating a fresh one if the name doesn't
  # exist on this runner. 90s cap on bootstatus so a hung sim doesn't burn
  # the whole CI budget.
  def _boot_named_sim!(device_name)
    list_json = `xcrun simctl list devices available --json 2>/dev/null`
    parsed = JSON.parse(list_json) rescue { "devices" => {} }
    match = nil
    (parsed["devices"] || {}).each do |runtime, devs|
      next unless runtime.include?("iOS")
      devs.each do |d|
        if d["name"] == device_name
          match = d
          break
        end
      end
      break if match
    end

    if match.nil?
      # Try to create the device against the highest available iOS runtime.
      runtimes = (parsed["devices"] || {}).keys.select { |r| r.include?("iOS") }.sort
      UI.user_error!("Simulator '#{device_name}' not available and no iOS runtime found on host") if runtimes.empty?
      runtime = runtimes.last
      device_types_json = `xcrun simctl list devicetypes --json 2>/dev/null`
      types = JSON.parse(device_types_json)["devicetypes"] rescue []
      type = types.find { |t| t["name"] == device_name }
      UI.user_error!("No simctl device type matches '#{device_name}'") unless type
      udid = sh("xcrun simctl create #{Shellwords.escape(device_name)} #{Shellwords.escape(type["identifier"])} #{Shellwords.escape(runtime)}").strip
      sh("xcrun simctl boot #{udid}")
      # 90s cap on bootstatus so a hung simulator doesn't burn the whole
      # macos-latest runner allocation. macOS doesn't ship GNU `timeout`;
      # use the perl-based alarm idiom which is universally available.
      sh("perl -e 'alarm shift @ARGV; exec @ARGV' 90 xcrun simctl bootstatus #{udid} -b")
      return udid
    end

    udid = match["udid"]
    if match["state"] != "Booted"
      sh("xcrun simctl boot #{udid}")
      # 90s cap on bootstatus so a hung simulator doesn't burn the whole
      # macos-latest runner allocation. macOS doesn't ship GNU `timeout`;
      # use the perl-based alarm idiom which is universally available.
      sh("perl -e 'alarm shift @ARGV; exec @ARGV' 90 xcrun simctl bootstatus #{udid} -b")
    end
    udid
  end

  desc "Capture fresh App Store screenshots via Maestro and stage them under fastlane/screenshots/"
  lane :screenshots_maestro do
    ensure_xcodegen_project!
    udid = _maestro_boot_ios_simulator!

    derived = File.join(IOS_ROOT, "build/maestro-derived")
    sh("rm -rf #{Shellwords.escape(derived)}")
    sh(
      "xcodebuild -project #{Shellwords.escape(PROJECT_PATH)} " \
      "-scheme #{Shellwords.escape(SCHEME)} " \
      "-configuration Debug " \
      "-destination 'platform=iOS Simulator,id=#{udid}' " \
      "-derivedDataPath #{Shellwords.escape(derived)} " \
      "CODE_SIGNING_ALLOWED=NO " \
      "build"
    )
    app_path = File.join(derived, "Build/Products/Debug-iphonesimulator/Safewords.app")
    sh("xcrun simctl install #{udid} #{Shellwords.escape(app_path)}")

    sh("rm -rf #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")
    sh("mkdir -p #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")

    _maestro_run_flow("screenshots.yaml")

    # Stage into the App Store Connect screenshots layout.
    # `fastlane deliver` expects fastlane/screenshots/<lang>/<DEVICE>_NN.png.
    # Default device is the iPhone 6.7-Display class — App Store accepts
    # one set per family. We deposit into en-US/ and let upload_to_app_store
    # pick them up.
    dest = File.join(SCREENSHOTS_PATH, "en-US")
    sh("rm -f #{Shellwords.escape(dest)}/*.png")
    sh("mkdir -p #{Shellwords.escape(dest)}")

    captures = Dir.glob(File.join(MAESTRO_SCREENSHOTS_DIR, "*.png")).sort
    if captures.empty?
      UI.user_error!("Maestro screenshots flow ran but produced no PNGs in #{MAESTRO_SCREENSHOTS_DIR}")
    end
    captures.each_with_index do |src, idx|
      base = File.basename(src, ".png").sub(/^\d+[-_]?/, "")
      target = File.join(dest, format("%02d_%s.png", idx + 1, base))
      FileUtils.cp(src, target)
      UI.message("staged #{File.basename(target)}")
    end
    UI.success("Captured #{captures.size} fresh screenshots into #{dest}")
  end

  desc "Capture App Store screenshots across the 6.7\"/6.5\"/5.5\"/12.9\" device matrix"
  lane :screenshots_matrix do
    ensure_xcodegen_project!

    # Build the .app once against an iPhone simulator destination — the same
    # binary runs on every iPhone/iPad simulator since it's a Universal build.
    derived = File.join(IOS_ROOT, "build/maestro-derived")
    sh("rm -rf #{Shellwords.escape(derived)}")

    sh("xcrun simctl shutdown all || true")

    # Boot the first device once, reusing :maestro_test's flow, so the build
    # destination is populated with real artifacts before the matrix loop.
    first_device = SCREENSHOT_MATRIX.first[0]
    first_udid = _boot_named_sim!(first_device)

    sh(
      "xcodebuild -project #{Shellwords.escape(PROJECT_PATH)} " \
      "-scheme #{Shellwords.escape(SCHEME)} " \
      "-configuration Debug " \
      "-destination 'platform=iOS Simulator,id=#{first_udid}' " \
      "-derivedDataPath #{Shellwords.escape(derived)} " \
      "CODE_SIGNING_ALLOWED=NO " \
      "build"
    )
    app_path = File.join(derived, "Build/Products/Debug-iphonesimulator/Safewords.app")
    UI.user_error!("Sim build did not produce #{app_path}") unless File.directory?(app_path)

    total = 0
    failed = []
    SCREENSHOT_MATRIX.each_with_index do |(device_name, subdir, label), idx|
      UI.message("=" * 70)
      UI.message("[#{idx + 1}/#{SCREENSHOT_MATRIX.size}] Capturing on #{label}")
      UI.message("=" * 70)

      udid =
        if idx.zero?
          first_udid
        else
          sh("xcrun simctl shutdown all || true")
          _boot_named_sim!(device_name)
        end

      sh("xcrun simctl install #{udid} #{Shellwords.escape(app_path)}")

      sh("rm -rf #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")
      sh("mkdir -p #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")

      flow_path = "screenshots.yaml"
      full = File.join(MAESTRO_FLOWS_DIR, flow_path)
      UI.user_error!("Maestro flow not found: #{full}") unless File.exist?(full)

      # Per-device tolerance — see the Android :screenshots_matrix lane for
      # the reasoning. Tablet/non-iPhone layouts can leave a tap target off
      # the screen edge; we capture whatever Maestro got and keep the matrix
      # going rather than aborting the whole run.
      flow_failed = false
      begin
        sh("bash -c '#{_maestro_path_prefix} cd #{Shellwords.escape(MAESTRO_FLOWS_DIR)} && maestro --device #{Shellwords.escape(udid)} test #{Shellwords.escape(flow_path)}'")
      rescue => e
        flow_failed = true
        UI.important("  Maestro flow errored on #{label}: #{e.message.lines.first&.strip}")
      end

      dest = File.join(SCREENSHOTS_PATH, "en-US", subdir)
      sh("rm -f #{Shellwords.escape(dest)}/*.png")
      sh("mkdir -p #{Shellwords.escape(dest)}")

      captures = Dir.glob(File.join(MAESTRO_SCREENSHOTS_DIR, "*.png")).sort
      if captures.empty?
        failed << "#{label} (no PNGs captured)"
        UI.error("  Maestro produced no PNGs for #{label}; skipping")
        next
      end
      captures.each_with_index do |src, i|
        base = File.basename(src, ".png").sub(/^\d+[-_]?/, "")
        target = File.join(dest, format("%02d_%s.png", i + 1, base))
        FileUtils.cp(src, target)
        UI.message("  staged #{File.basename(target)}")
      end
      total += captures.size
      if flow_failed
        failed << "#{label} (partial: #{captures.size}/6)"
        UI.important("  #{label}: #{captures.size}/6 PNGs (partial) → #{dest}")
      else
        UI.success("  #{label}: #{captures.size} PNGs → #{dest}")
      end
    end

    sh("xcrun simctl shutdown all || true")
    if failed.any?
      UI.important("screenshots_matrix produced #{total} PNGs across #{SCREENSHOT_MATRIX.size} device classes; failures on: #{failed.join('; ')}")
    else
      UI.success("screenshots_matrix produced #{total} PNGs across #{SCREENSHOT_MATRIX.size} device classes")
    end
  end

end
