default_platform(:android)

require "fileutils"
require "shellwords"

# ───────────────────────────────────────────────────────────────────
# Safewords release pipeline
#
# Driven by claude after the user explicitly delegated release pushing
# on 2026-04-29. The Play Console GUI is fragile (silent rejections,
# ambiguous errors); the supply API is the load-bearing path.
#
# Common lanes:
#   fastlane build           - bundleRelease, output AAB to ../../../output/play-store/v2/
#   fastlane internal        - build + push to internal testing
#   fastlane closed          - build + push to closed testing (alpha)
#   fastlane production      - build + push to production (with confirm)
#   fastlane promote_to_prod - promote latest internal release to production
#   fastlane metadata        - push listing copy + screenshots only, no AAB
#   fastlane validate        - dry-run upload, useful for pre-release sanity
# ───────────────────────────────────────────────────────────────────

OUTPUT_DIR = File.expand_path("../../../output/play-store/v2", __dir__)
AAB_PATH = "#{OUTPUT_DIR}/app-release.aab"

# Maestro flow runner — see docs/release-pipeline-gotchas.md (Maestro section).
# u5 (and any non-interactive ssh shell) doesn't have ~/.maestro/bin or
# ~/android-sdk/platform-tools on PATH; the Maestro installer only edits
# ~/.bashrc and ~/.zshrc. Export PATH explicitly inside the shell string we
# hand to fastlane's `sh` action so the gradle/adb/maestro lookups all resolve.
MAESTRO_FLOWS_DIR = File.expand_path("../../../maestro/flows", __dir__)
MAESTRO_SCREENSHOTS_DIR = File.expand_path("../../../maestro/screenshots", __dir__)

def maestro_path_prefix
  # Prepend instead of append so an explicitly-installed maestro/adb wins
  # over any system version. ANDROID_HOME is needed by adb's protocol probe.
  %(export PATH="$HOME/.maestro/bin:$HOME/android-sdk/platform-tools:$PATH"; ) +
    %(export ANDROID_HOME="${ANDROID_HOME:-$HOME/android-sdk}"; ) +
    %(export MAESTRO_CLI_NO_ANALYTICS=1; ) +
    %(export MAESTRO_CLI_ANALYSIS_NOTIFICATION_DISABLED=true; )
end

# Run a single Maestro flow against the connected emulator. The flow path is
# resolved relative to maestro/flows/. Fastlane's sh action raises on any
# non-zero exit; that's the fail-closed contract the smoke gate relies on.
# Named with a leading underscore so it doesn't collide with the :maestro_test
# lane (fastlane resolves bare names against the lane registry).
def _maestro_run_flow(flow_path)
  full = File.join(MAESTRO_FLOWS_DIR, flow_path)
  UI.user_error!("Maestro flow not found: #{full}") unless File.exist?(full)
  sh("bash -c '#{maestro_path_prefix} cd #{Shellwords.escape(MAESTRO_FLOWS_DIR)} && maestro test #{Shellwords.escape(flow_path)}'")
end

# Read keystore creds from ~/keystores/safewords-release.password on the build
# host. Don't put them in version control.
#
# We export env vars BEFORE the gradle invocation in a single shell string,
# rather than passing them via fastlane's sh(env:) param — the latter doesn't
# propagate through the "cd .. && ./gradlew" composite into the gradle JVM
# subprocess, so the signing config falls back to an empty password and the
# build fails with "keystore password was incorrect" even though the actual
# password is valid.
def keystore_env
  {
    "SAFEWORDS_KEYSTORE_PATH"     => "#{ENV['HOME']}/keystores/safewords-release.jks",
    "SAFEWORDS_KEYSTORE_PASSWORD" => ENV["SAFEWORDS_KEYSTORE_PASSWORD"] || `cat #{ENV['HOME']}/keystores/safewords-release.password 2>/dev/null`.strip,
    "SAFEWORDS_KEY_ALIAS"         => "safewords",
    "SAFEWORDS_KEY_PASSWORD"      => ENV["SAFEWORDS_KEY_PASSWORD"] || `cat #{ENV['HOME']}/keystores/safewords-release.password 2>/dev/null`.strip,
  }
end

platform :android do

  desc "Build a signed release AAB and stage it in the play-store output directory"
  lane :build do
    # Write the keystore env vars to a temp file with 0600 perms, source it,
    # then run gradle. Avoids ever printing the password to the terminal or
    # baking it into ps argv. fastlane's sh action prints the command verbatim,
    # so we keep the visible command opaque.
    require "tempfile"
    envfile = Tempfile.new("safewords-keystore")
    begin
      envfile.write(keystore_env.map { |k, v| "export #{k}=#{Shellwords.escape(v)}" }.join("\n") + "\n")
      envfile.close
      File.chmod(0o600, envfile.path)
      sh("bash -c 'set -a; source #{Shellwords.escape(envfile.path)}; set +a; cd .. && ./gradlew clean :app:bundleRelease'")
    ensure
      envfile.unlink
    end
    sh("mkdir -p #{OUTPUT_DIR}")
    sh("cp ../app/build/outputs/bundle/release/app-release.aab #{OUTPUT_DIR}/")

    # Stamp a versioned copy too so we keep history
    version_name = sh("cd .. && ./gradlew :app:properties -q 2>/dev/null | awk -F': ' '/^android.defaultConfig.versionName:/{print $2}'").strip
    if !version_name.empty?
      sh("cp #{OUTPUT_DIR}/app-release.aab #{OUTPUT_DIR}/safewords-#{version_name}.aab")
    end
    UI.success("Built AAB at #{AAB_PATH}")
  end

  desc "Build + push to internal testing track (bundles AAB + metadata + listing assets)"
  lane :internal do
    # Smoke gate. Fails closed before any AAB upload — if the four phase-1
    # Maestro flows don't all pass against a fresh debug APK, we never push
    # to Play. See docs/maestro-plan.md.
    maestro_test
    build
    upload_to_play_store(
      track: "internal",
      aab: AAB_PATH,
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      validate_only: false,
    )
    UI.success("v#{current_version} + listing metadata pushed to internal testing as DRAFT")
  end

  desc "Build + push to closed testing (alpha)"
  lane :closed do
    build
    upload_to_play_store(
      track: "alpha",
      aab: AAB_PATH,
      release_status: "completed",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("v#{current_version} pushed to closed testing")
  end

  desc "Build + push to production (CONFIRMS first)"
  lane :production do
    UI.important("ABOUT TO PUSH TO PRODUCTION. This is user-visible.")
    confirmed = UI.confirm("Continue?")
    UI.user_error!("Aborted") unless confirmed
    build
    upload_to_play_store(
      track: "production",
      aab: AAB_PATH,
      release_status: "completed",
      rollout: "0.1", # 10% staged rollout to start, can be raised after
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("v#{current_version} pushed to production at 10% rollout")
  end

  desc "Promote the latest internal release to production (no rebuild)"
  lane :promote_to_prod do
    UI.important("ABOUT TO PROMOTE INTERNAL → PRODUCTION. User-visible.")
    confirmed = UI.confirm("Continue?")
    UI.user_error!("Aborted") unless confirmed
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      release_status: "completed",
      rollout: "0.1",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("Internal release promoted to production at 10%")
  end

  desc "Re-capture all phone screenshots from a live emulator and stage them in fastlane/metadata/"
  lane :screenshots do
    sh("cd .. && ./gradlew assembleDebug")
    sh("bash #{__dir__}/screenshot_walkthrough.sh")
    UI.success("Captured fresh screenshots — push them with `fastlane internal` (next AAB upload bundles them) or `fastlane metadata` once app is past draft state")
  end

  desc "Push only listing copy + screenshots, no AAB"
  lane :metadata do
    upload_to_play_store(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      track: "internal",
      release_status: "draft", # required while the app is in pre-production draft state
    )
    UI.success("Listing metadata + assets pushed")
  end

  desc "Dry-run validation against Play API — confirms credentials + AAB are accepted"
  lane :validate do
    upload_to_play_store(
      track: "internal",
      aab: AAB_PATH,
      validate_only: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("Validation passed — credentials work, AAB accepted by Play API")
  end

  desc "Run Maestro phase-1 smoke flows against the connected emulator. Fails closed."
  lane :maestro_test do
    # Build a fresh debug APK and install it so the Maestro flows target the
    # current source tree (testTags, accessibility IDs, demo seed, etc).
    sh("bash -c '#{maestro_path_prefix} cd ../app && ../gradlew :app:assembleDebug'")
    apk = File.expand_path("../app/build/outputs/apk/debug/app-debug.apk", __dir__)
    UI.user_error!("Debug APK missing at #{apk}") unless File.exist?(apk)
    sh("bash -c '#{maestro_path_prefix} adb install -r #{Shellwords.escape(apk)}'")

    # Pre-warm: the AVD may be on the dim/lock screen between runs. Maestro's
    # launchApp can wake it but the first tap occasionally lands on the lock
    # gesture rather than the app. Sending KEYCODE_WAKEUP up-front is cheap.
    sh("bash -c '#{maestro_path_prefix} adb shell input keyevent KEYCODE_WAKEUP || true'")

    %w[
      onboarding-create.yaml
      onboarding-restore.yaml
      onboarding-demo.yaml
      parity-check.yaml
    ].each do |flow|
      UI.message("Maestro flow: #{flow}")
      _maestro_run_flow(flow)
    end

    UI.success("All 4 phase-1 Maestro flows passed")
  end

  # Device matrix for the Play Store screenshot mandate. Each tuple is:
  # [avd_name, output_subdir_under_images, label_for_logs].
  #
  # The phone slot is the same Pixel 6 AVD the dev-loop :screenshots_maestro
  # lane targets. The tablet slots are pre-created on u5 — the lane fails
  # closed with the avdmanager invocation if they're missing rather than
  # silently downloading a 1.5 GB system image at boot time.
  SCREENSHOT_MATRIX = [
    ["pixel",                "phoneScreenshots",     "Phone (Pixel 6)"],
    ["Nexus_7_API_33",       "sevenInchScreenshots", "7\" tablet (Nexus 7)"],
    ["Pixel_Tablet_API_33",  "tenInchScreenshots",   "10\" tablet (Pixel Tablet)"]
  ].freeze

  desc "Capture fresh listing screenshots via Maestro and stage them under fastlane/metadata/"
  lane :screenshots_maestro do
    sh("bash -c '#{maestro_path_prefix} cd ../app && ../gradlew :app:assembleDebug'")
    apk = File.expand_path("../app/build/outputs/apk/debug/app-debug.apk", __dir__)
    sh("bash -c '#{maestro_path_prefix} adb install -r #{Shellwords.escape(apk)}'")
    sh("bash -c '#{maestro_path_prefix} adb shell input keyevent KEYCODE_WAKEUP || true'")

    # Wipe stale captures so a partial run doesn't pick up old PNGs.
    sh("rm -rf #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")
    sh("mkdir -p #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")

    _maestro_run_flow("screenshots.yaml")

    # Map Maestro captures (named NN-label.png by the flow) into the supply
    # API's expected layout (fastlane/metadata/.../phoneScreenshots/N_*.png).
    # screenshots.yaml writes ../screenshots/01-onboarding.png etc; supply
    # wants 1_*, 2_* etc as the listing order.
    dest = File.expand_path("metadata/android/en-US/images/phoneScreenshots", __dir__)
    sh("rm -f #{Shellwords.escape(dest)}/*.png")
    sh("mkdir -p #{Shellwords.escape(dest)}")

    captures = Dir.glob(File.join(MAESTRO_SCREENSHOTS_DIR, "*.png")).sort
    if captures.empty?
      UI.user_error!("Maestro screenshots flow ran but produced no PNGs in #{MAESTRO_SCREENSHOTS_DIR}")
    end
    captures.each_with_index do |src, idx|
      base = File.basename(src, ".png").sub(/^\d+[-_]?/, "")
      target = File.join(dest, "#{idx + 1}_#{base}.png")
      FileUtils.cp(src, target)
      UI.message("staged #{File.basename(target)}")
    end
    UI.success("Captured #{captures.size} fresh screenshots into #{dest}")
  end

  desc "Capture listing screenshots across the Play-mandated phone + 7\" + 10\" device matrix"
  lane :screenshots_matrix do
    # Build + install once per device class — install happens after each AVD
    # boot since freshly-booted AVDs ship with no user-installed packages.
    sh("bash -c '#{maestro_path_prefix} cd ../app && ../gradlew :app:assembleDebug'")
    apk = File.expand_path("../app/build/outputs/apk/debug/app-debug.apk", __dir__)
    UI.user_error!("Debug APK missing at #{apk}") unless File.exist?(apk)

    available = `bash -c '#{maestro_path_prefix} ${ANDROID_HOME}/emulator/emulator -list-avds 2>/dev/null'`.split("\n").map(&:strip)
    missing = SCREENSHOT_MATRIX.map { |avd, _, _| avd } - available
    if missing.any?
      hint = missing.map do |name|
        device_id =
          case name
          when /Nexus_?7/i      then "Nexus 7"
          when /Pixel.?Tablet/i then "pixel_tablet"
          else "pixel_6"
          end
        %(echo "no" | $ANDROID_HOME/cmdline-tools/latest/bin/avdmanager create avd ) +
          %(--name "#{name}" --device "#{device_id}" --package "system-images;android-34;google_apis;x86_64" --force)
      end.join("\n  ")
      UI.user_error!(
        "AVD(s) not present on this host: #{missing.join(', ')}.\n" \
        "Pre-create them before running this lane:\n  #{hint}\n" \
        "Auto-creation is intentionally disabled — system-image downloads can take 5+ minutes."
      )
    end

    total = 0
    failed = []
    SCREENSHOT_MATRIX.each_with_index do |(avd, subdir, label), idx|
      UI.message("=" * 70)
      UI.message("[#{idx + 1}/#{SCREENSHOT_MATRIX.size}] Capturing on #{label} (avd=#{avd})")
      UI.message("=" * 70)

      # Stop any running emulator. `adb emu kill` only targets the emulator
      # currently bound to default port 5554; pkill -x catches stragglers
      # from a prior matrix iteration that may not have shut down cleanly.
      # We use exact-name matching (-x) rather than -f so the kill doesn't
      # accidentally match its own command line (which contains the literal
      # string "emulator" thanks to ANDROID_HOME/emulator/emulator) and
      # SIGTERM the bash interpreter that's still trying to reach `exit 0`.
      sh("bash -c '#{maestro_path_prefix} adb emu kill 2>/dev/null || true; pkill -x qemu-system-x86_64 2>/dev/null || true; pkill -x emulator64-crash-service 2>/dev/null || true; pkill -x emulator 2>/dev/null || true; exit 0'")
      sleep 2

      # Boot headless. -no-snapshot avoids loading a stale post-onboarding
      # state across iterations; -no-audio + swiftshader_indirect keep it
      # quiet and GPU-friendly on the u5 dev VM.
      boot_cmd = %(bash -c '#{maestro_path_prefix} ) +
        %(nohup $ANDROID_HOME/emulator/emulator -avd #{Shellwords.escape(avd)} ) +
        %(-no-window -no-audio -no-snapshot -gpu swiftshader_indirect ) +
        %(>/tmp/emu-#{avd}.log 2>&1 &')
      sh(boot_cmd)

      # Block until boot_completed=1 or 120s elapse.
      sh(%(bash -c '#{maestro_path_prefix} ) +
         %(for i in $(seq 1 120); do ) +
         %(  out=$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d "\\r"); ) +
         %(  if [ "$out" = "1" ]; then echo "boot ok"; exit 0; fi; ) +
         %(  sleep 1; ) +
         %(done; ) +
         %(echo "boot timeout for #{avd}" >&2; exit 1' ))
      sh("bash -c '#{maestro_path_prefix} adb wait-for-device'")
      # Settle the launcher — without this Maestro occasionally taps through
      # the unlock animation rather than the welcome CTA.
      sh("bash -c '#{maestro_path_prefix} adb shell input keyevent KEYCODE_WAKEUP || true'")
      sleep 3

      sh("bash -c '#{maestro_path_prefix} adb install -r #{Shellwords.escape(apk)}'")

      # Wipe stale captures so we never accidentally fold one device's PNGs
      # into another's directory.
      sh("rm -rf #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")
      sh("mkdir -p #{Shellwords.escape(MAESTRO_SCREENSHOTS_DIR)}")

      # Per-device tolerance: if the flow throws on a tablet (e.g. layout
      # differences leave a CTA off-screen) we still want to stage whatever
      # screenshots Maestro got to before the failure, then move on. The lane
      # ends with a non-zero exit if any device class came up empty so CI can
      # gate on it; partial captures are surfaced as a warning.
      flow_failed = false
      begin
        _maestro_run_flow("screenshots.yaml")
      rescue => e
        flow_failed = true
        UI.important("  Maestro flow errored on #{label}: #{e.message.lines.first&.strip}")
      end

      dest = File.expand_path("metadata/android/en-US/images/#{subdir}", __dir__)
      sh("rm -f #{Shellwords.escape(dest)}/*.png")
      sh("mkdir -p #{Shellwords.escape(dest)}")

      captures = Dir.glob(File.join(MAESTRO_SCREENSHOTS_DIR, "*.png")).sort
      if captures.empty?
        failed << "#{label} (no PNGs captured; emu log /tmp/emu-#{avd}.log)"
        UI.error("  Maestro produced no PNGs for #{label}; skipping")
        next
      end
      captures.each_with_index do |src, i|
        base = File.basename(src, ".png").sub(/^\d+[-_]?/, "")
        target = File.join(dest, "#{i + 1}_#{base}.png")
        FileUtils.cp(src, target)
        UI.message("  staged #{File.basename(target)}")
      end
      total += captures.size
      if flow_failed
        failed << "#{label} (partial: #{captures.size}/6)"
        UI.important("  #{label}: #{captures.size}/6 PNGs (partial) → #{dest}")
      else
        UI.success("  #{label}: #{captures.size} PNGs → #{dest}")
      end
    end

    # Final teardown so we leave the host in a clean state.
    sh("bash -c '#{maestro_path_prefix} adb emu kill 2>/dev/null || true; pkill -x qemu-system-x86_64 2>/dev/null || true; pkill -x emulator 2>/dev/null || true; exit 0'")

    if failed.any?
      UI.important("screenshots_matrix produced #{total} PNGs across #{SCREENSHOT_MATRIX.size} device classes; failures on: #{failed.join('; ')}")
    else
      UI.success("screenshots_matrix produced #{total} PNGs across #{SCREENSHOT_MATRIX.size} device classes")
    end
  end

  # ─── Helpers ────────────────────────────────────────────────────

  def current_version
    `cd .. && ./gradlew :app:properties -q 2>/dev/null | awk -F': ' '/^android.defaultConfig.versionName:/{print $2}'`.strip
  end
end
